# Python
.venv/
__pycache__/
*.pyc

# Ableton analysis files (auto-generated)
*.asd

# macOS
.DS_Store

# Audio files (too large for git)
*.aif
*.aiff
*.wav
*.mp3
*.flac
*.m4a

# Ableton project files
*.als
*.alc

# Binary content directories (contents ignored, .gitkeep tracked)
Projects/**
!Projects/.gitkeep
Recordings/**
!Recordings/.gitkeep
!Recordings/*/
!Recordings/**/.gitkeep
Samples/**
!Samples/.gitkeep

# Claude working files
Claude/**
!Claude/.gitkeep

# Temp files
.playwright-mcp/
